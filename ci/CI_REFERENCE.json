          "identity/**",
          "providers/**",
          "runtime/**",
          "services/**",
          "ui/**",
          "tests/**",
          ".github/workflows/reusable_quality.yml",
          ".github/workflows/quality_fast.yml",
          "ci/**",
          "pyproject.toml",
          "pytest.ini",
          "mypy.ini"
